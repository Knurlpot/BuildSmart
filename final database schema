-- 1. Company Table
CREATE TABLE company (
    company_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    company_name VARCHAR(75) NOT NULL,
    company_address VARCHAR(255) NOT NULL,
    contact_email VARCHAR(100) NOT NULL UNIQUE,
    contact_number VARCHAR(20) NOT NULL,
    specialization_1 VARCHAR(50) NOT NULL,
    specialization_2 VARCHAR(50),
    specialization_3 VARCHAR(50),
    status VARCHAR(20) NOT NULL CHECK (status IN ('Active', 'Inactive')),
    company_logo VARCHAR(255),
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- 2. Users Table
CREATE TABLE users (
    user_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    company_id INT NOT NULL REFERENCES company(company_id) ON DELETE CASCADE,
    last_name VARCHAR(30) NOT NULL,
    first_name VARCHAR(30) NOT NULL,
    middle_name VARCHAR(30),
    email VARCHAR(50) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL, -- Increased size from 50 to accommodate standard password hashes like bcrypt
    user_role VARCHAR(50) NOT NULL CHECK (user_role IN ('Owner', 'Admin', 'Estimator', 'Viewer')),
    status VARCHAR(30) NOT NULL CHECK (status IN ('Active', 'Inactive')),
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- 3. Suppliers Table
CREATE TABLE suppliers (
    supplier_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    supplier_name VARCHAR(50) NOT NULL,
    supplier_address VARCHAR(100) NOT NULL,
    warehouse_loc VARCHAR(50) NOT NULL,
    city VARCHAR(40) NOT NULL,
    region VARCHAR(20) NOT NULL,
    contact_email VARCHAR(30) NOT NULL,
    contact_number VARCHAR(20) NOT NULL,
    supplier_type VARCHAR(30) NOT NULL CHECK (supplier_type IN ('Distributor', 'Warehouse', 'Retailer')),
    status VARCHAR(20) NOT NULL CHECK (status IN ('Active', 'Inactive'))
);

-- 4. Supplier Benchmark Table
CREATE TABLE supplier_benchmark (
    benchmark_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    supplier_id INT NOT NULL REFERENCES suppliers(supplier_id) ON DELETE CASCADE,
    average_price_score DECIMAL(5, 2),
    update_frequency_score DECIMAL(5, 2),
    reliability_score DECIMAL(5, 2),
    delivery_score DECIMAL(5, 2),
    overall_score DECIMAL(5, 2)
);

-- 5. Supplier Region Table
CREATE TABLE supplier_region (
    region_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    supplier_id INT NOT NULL REFERENCES suppliers(supplier_id) ON DELETE CASCADE,
    region VARCHAR(40) NOT NULL CHECK (region IN (
        'Region I', 'Region II', 'Region III', 'Region IV-A', 'Region IV-B', 
        'Region V', 'Region VI', 'Region VII', 'Region VIII', 'Region IX', 
        'Region X', 'Region XI', 'Region XII', 'Region XIII', 'CAR', 'NCR', 'NIR', 'BARMM'
    )),
    province VARCHAR(40) NOT NULL,
    city VARCHAR(40) NOT NULL
);

-- 6. Supplier Discount Rule Table
CREATE TABLE supplier_discount_rule (
    supplierdisc_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    company_id INT NOT NULL REFERENCES company(company_id) ON DELETE CASCADE,
    supplier_id INT NOT NULL REFERENCES suppliers(supplier_id) ON DELETE CASCADE,
    rule_type VARCHAR(40) NOT NULL CHECK (rule_type IN ('Bulk discount', 'Negotiated price', 'Minimum order', 'Preferred supplier')),
    minimum_order_amount DECIMAL(15, 2),
    discount_percentage_rate DECIMAL(5, 2),
    fixed_discount_amount DECIMAL(15, 2),
    effective_date DATE NOT NULL,
    expiration_date DATE,
    is_active BOOLEAN NOT NULL DEFAULT TRUE
);

-- 7. Category Table
CREATE TABLE category (
    category_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    category_type VARCHAR(40) NOT NULL,
    category_desc VARCHAR(70) NOT NULL
);

-- 8. Items Table
CREATE TABLE items (
    item_code INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    category_id INT NOT NULL REFERENCES category(category_id),
    company_id INT REFERENCES company(company_id) ON DELETE SET NULL,
    item_name VARCHAR(50) NOT NULL,
    material VARCHAR(50) NOT NULL,
    brand VARCHAR(50) NOT NULL,
    quality VARCHAR(50),
    unit VARCHAR(50) NOT NULL,
    size_width DECIMAL(5, 2) NOT NULL,
    size_length DECIMAL(5, 2) NOT NULL,
    color VARCHAR(40) NOT NULL,
    item_source VARCHAR(10) NOT NULL CHECK (item_source IN ('DPWH', 'PSA', 'Others')),
    description VARCHAR(70)
);

-- 9. Historical Price Record Table
CREATE TABLE historical_price_record (
    historicalrec_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    item_code INT NOT NULL REFERENCES items(item_code) ON DELETE CASCADE,
    supplier_id INT NOT NULL REFERENCES suppliers(supplier_id) ON DELETE CASCADE,
    source VARCHAR(30) NOT NULL CHECK (source IN ('DPWH', 'PSA', 'Supplier Upload')),
    region VARCHAR(30),
    quarter VARCHAR(30) NOT NULL,
    year INT NOT NULL,
    price DECIMAL(12, 2) NOT NULL,
    recorded_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- 10. Material Price Variance Table
CREATE TABLE material_price_variance (
    mpv_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    item_code INT NOT NULL REFERENCES items(item_code) ON DELETE CASCADE,
    quarter VARCHAR(2) NOT NULL,
    year INT NOT NULL,
    percent_change DECIMAL(5, 2) NOT NULL,
    trend_direction VARCHAR(20) NOT NULL CHECK (trend_direction IN ('Up', 'Down', 'Stable')),
    is_significant_spike BOOLEAN NOT NULL DEFAULT FALSE
);

-- 11. Quotation Table
CREATE TABLE quotation (
    quote_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    company_id INT NOT NULL REFERENCES company(company_id) ON DELETE CASCADE,
    user_id INT NOT NULL REFERENCES users(user_id),
    project_name VARCHAR(50) NOT NULL,
    project_location VARCHAR(50) NOT NULL,
    project_region VARCHAR(50) NOT NULL,
    input_method VARCHAR(50) NOT NULL,
    status VARCHAR(50) NOT NULL CHECK (status IN ('Draft', 'Final')),
    total_material_cost DECIMAL(15, 2) NOT NULL,
    total_service_cost DECIMAL(15, 2) NOT NULL,
    grand_total DECIMAL(15, 2) NOT NULL,
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- 12. Quotation Items Table
CREATE TABLE quotation_items (
    quote_item_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    quote_id INT NOT NULL REFERENCES quotation(quote_id) ON DELETE CASCADE,
    item_code INT NOT NULL REFERENCES items(item_code),
    quantity INT NOT NULL,
    unit_cost DECIMAL(12, 2) NOT NULL,
    markup_percentage DECIMAL(5, 2) NOT NULL CHECK (markup_percentage BETWEEN 0.00 AND 100.00),
    final_unit_price DECIMAL(15, 2) NOT NULL,
    total_cost DECIMAL(15, 2) NOT NULL,
    source_type VARCHAR(30) NOT NULL CHECK (source_type IN ('DPWH', 'PSA', 'Internal', 'Supplier'))
);

-- 13. Quotation Service Cost Table
CREATE TABLE quotation_service_cost (
    service_cost_id INT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    quote_id INT NOT NULL REFERENCES quotation(quote_id) ON DELETE CASCADE,
    service_type VARCHAR(100) NOT NULL,
    description VARCHAR(255),
    labor_cost DECIMAL(12, 2) NOT NULL,
    equipment_cost DECIMAL(15, 2) NOT NULL,
    contingency_cost DECIMAL(15, 2) NOT NULL,
    other_cost DECIMAL(15, 2) NOT NULL,
    subtotal DECIMAL(15, 2) NOT NULL
);
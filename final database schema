-- Company Table
CREATE TABLE company (
    company_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    company_name VARCHAR(75) NOT NULL,
    company_address VARCHAR(255) NOT NULL,
    contact_email VARCHAR(100) NOT NULL UNIQUE,
    contact_number VARCHAR(20) NOT NULL,
    specialization_1 VARCHAR(50) NOT NULL,
    specialization_2 VARCHAR(50),
    specialization_3 VARCHAR(50),
    status VARCHAR(20) NOT NULL CHECK (status IN ('Active', 'Inactive')),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL
);

-- Users Table
CREATE TABLE users (
    user_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    company_id INT(11) NOT NULL,
    last_name VARCHAR(30) NOT NULL,
    first_name VARCHAR(30) NOT NULL,
    middle_name VARCHAR(30),
    email VARCHAR(50) NOT NULL UNIQUE,
    password VARCHAR(50) NOT NULL,
    user_role VARCHAR(50) NOT NULL CHECK (user_role IN ('Owner', 'Admin', 'Estimator', 'Viewer')),
    status VARCHAR(30) NOT NULL CHECK (status IN ('Active', 'Inactive')),
    created_at VARCHAR(30) NOT NULL,
    FOREIGN KEY (company_id) REFERENCES companies(company_id)
);

-- Suppliers Table
CREATE TABLE suppliers (
    supplier_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    supplier_name VARCHAR(50) NOT NULL,
    supplier_address VARCHAR(100) NOT NULL,
    warehouse_loc VARCHAR(50) NOT NULL,
    city VARCHAR(40) NOT NULL,
    region VARCHAR(20) NOT NULL,
    contact_email VARCHAR(30) NOT NULL,
    contact_number VARCHAR(20) NOT NULL,
    supplier_type VARCHAR(30) NOT NULL CHECK (supplier_type IN ('Distributor', 'Warehouse', 'Retailer')),
    status VARCHAR(20) NOT NULL CHECK (status IN ('Active', 'Inactive'))
);

-- Supplier Benchmarks
CREATE TABLE supplier_benchmarks (
    benchmark_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    supplier_id INT(11) NOT NULL,
    average_price_score DECIMAL(5, 2),
    update_frequency_score DECIMAL(5, 2),
    reliability_score DECIMAL(5, 2),
    delivery_score DECIMAL(5, 2),
    overall_score DECIMAL(5, 2),
    FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id)
);

-- Supplier Region
CREATE TABLE supplier_regions (
    region_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    supplier_id INT(11) NOT NULL,
    region VARCHAR(40) NOT NULL,
    province VARCHAR(40) NOT NULL,
    city VARCHAR(40) NOT NULL,
    FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id)
);

-- Supplier Discount Rules
CREATE TABLE supplier_discount_rules (
    supplierdisc_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    company_id INT(11) NOT NULL,
    supplier_id INT(11) NOT NULL,
    rule_type VARCHAR(40) NOT NULL CHECK (rule_type IN ('Bulk discount', 'Negotiated price', 'Minimum order', 'Preferred supplier')),
    minimum_order_amount DECIMAL(15, 2),
    discount_percentage DECIMAL(5, 2),
    fixed_discount_amount DECIMAL(5, 2),
    effective_date DATE NOT NULL,
    expiration_date DATE,
    is_active BOOLEAN NOT NULL,
    FOREIGN KEY (company_id) REFERENCES companies(company_id),
    FOREIGN KEY (supplier_id) REFERENCES suppliers(supplier_id)
);


-- Categories Table
CREATE TABLE categories (
    category_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    category_type VARCHAR(40) NOT NULL,
    name VARCHAR(70) NOT NULL,
    category_desc VARCHAR(70),
    explanation VARCHAR(255)
);

-- Items Table
CREATE TABLE items (
    item_code INT(11) AUTO_INCREMENT PRIMARY KEY,
    category_id INT(11) NOT NULL,
    company_id INT(11),
    item_name VARCHAR(50) NOT NULL,
    material VARCHAR(50) NOT NULL,
    brand VARCHAR(50) NOT NULL,
    quality VARCHAR(50),
    unit VARCHAR(50) NOT NULL,
    size_width DECIMAL(5, 2) NOT NULL,
    size_length DECIMAL(5, 2) NOT NULL,
    color VARCHAR(40) NOT NULL,
    item_source VARCHAR(10) NOT NULL CHECK (item_source IN ('DPWH', 'PSA', 'Others')),
    description VARCHAR(70),
    FOREIGN KEY (category_id) REFERENCES categories(category_id),
    FOREIGN KEY (company_id) REFERENCES companies(company_id)
);

-- Historical Price Records Table
CREATE TABLE historical_price_records (
    historicalrec_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    item_code INT(11) NOT NULL,
    source VARCHAR(30) NOT NULL CHECK (source IN ('DPWH', 'PSA', 'Supplier Upload')),
    region VARCHAR(30),
    quarter VARCHAR(30) NOT NULL,
    year INT(4) NOT NULL,
    price DECIMAL(12, 2) NOT NULL,
    recorded_at TIMESTAMP NOT NULL,
    FOREIGN KEY (item_code) REFERENCES items(item_code)
);

-- Material Price Variances Table
CREATE TABLE material_price_variances (
    mpv_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    item_code INT(11) NOT NULL,
    quarter VARCHAR(2) NOT NULL,
    year INT(4) NOT NULL,
    percent_change DECIMAL(5, 2) NOT NULL,
    trend_direction VARCHAR(20) NOT NULL CHECK (trend_direction IN ('Up', 'Down', 'Stable')),
    is_significant_spike BOOLEAN NOT NULL,
    FOREIGN KEY (item_code) REFERENCES items(item_code)
);

-- Quotations Table
CREATE TABLE quotations (
    quote_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    company_id INT(11) NOT NULL,
    user_id INT(11) NOT NULL,
    project_name VARCHAR(50) NOT NULL,
    project_location VARCHAR(50) NOT NULL,
    project_region VARCHAR(50) NOT NULL,
    input_method VARCHAR(50) NOT NULL,
    status VARCHAR(50) NOT NULL CHECK (status IN ('Draft', 'Final')),
    total_material_cost DECIMAL(15, 2) NOT NULL,
    total_service_cost DECIMAL(15, 2) NOT NULL,
    grand_total DECIMAL(15, 2) NOT NULL,
    created_at TIMESTAMP NOT NULL,
    updated_at TIMESTAMP NOT NULL,
    FOREIGN KEY (company_id) REFERENCES companies(company_id),
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

-- Quotation Items Table
CREATE TABLE quotation_items (
    quote_item_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    quote_id INT(11) NOT NULL,
    item_code INT(11) NOT NULL,
    quantity INT(5) NOT NULL,
    unit_cost DECIMAL(12, 2) NOT NULL,
    markup_percentage DECIMAL(5, 2) NOT NULL CHECK (markup_percentage BETWEEN 0.00 AND 100.00),
    final_unit_price DECIMAL(15, 2) NOT NULL,
    total_cost DECIMAL(15, 2) NOT NULL,
    source_type VARCHAR(30) NOT NULL CHECK (source_type IN ('DPWH', 'PSA', 'Internal', 'Supplier')),
    FOREIGN KEY (quote_id) REFERENCES quotations(quote_id),
    FOREIGN KEY (item_code) REFERENCES items(item_code)
);

-- Quotation Service Costs Table
CREATE TABLE quotation_service_costs (
    service_cost_id INT(11) AUTO_INCREMENT PRIMARY KEY,
    quote_id INT(11) NOT NULL,
    service_type VARCHAR(100) NOT NULL,
    description VARCHAR(255),
    labor_cost DECIMAL(12, 2) NOT NULL,
    equipment_cost DECIMAL(15, 2) NOT NULL,
    contingency_cost DECIMAL(15, 2) NOT NULL,
    other_cost DECIMAL(15, 2) NOT NULL,
    subtotal DECIMAL(15, 2) NOT NULL,
    FOREIGN KEY (quote_id) REFERENCES quotations(quote_id)
);